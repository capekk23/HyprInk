# Maintainer: HyprInk contributors

pkgname=hyprink
pkgver=1.0
pkgrel=1
pkgdesc='Persistent desktop notes and scribbles for Hyprland'
arch=('x86_64')
url='https://github.com/capekk23/HyprInk'
license=('MIT')
depends=('gtkmm3' 'gtk-layer-shell' 'jsoncpp')
makedepends=('cmake')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('f02f7b62258ccf91bbeaaaeb1ed2202e14665ab4c9f5af9d36c4c4b7db1f0ed2')

build() {
  cmake -S "HyprInk-${pkgver}" -B build \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build build
}

package() {
  DESTDIR="${pkgdir}" cmake --install build
}
